        </div>
      </div>
    </div>
    <script>
      (function() {
        var progressBar = document.getElementById('preloader-progress-bar');
        var percentageText = document.getElementById('preloader-percentage');
        var progress = 0;
        var loaded = false;

        // Dynamic crawling loading animation (no absolute freezes)
        var interval = setInterval(function() {
          if (progress < 90) {
            // Smooth, natural count up to 90% (takes about 1.1s on average)
            progress += Math.floor(Math.random() * 3) + 1;
            if (progress > 90) progress = 90;
          } else if (progress < 99) {
            // Crawl extremely slowly from 90% to 99% if still loading
            if (Math.random() > 0.8) {
              progress += 1;
            }
          }
          
          if (progressBar) progressBar.style.width = progress + '%';
          if (percentageText) percentageText.textContent = (progress < 10 ? '0' : '') + progress;
        }, 25);

        function completePreloader() {
          if (loaded) return;
          loaded = true;
          clearInterval(interval);
          
          progress = 100;
          if (progressBar) progressBar.style.width = '100%';
          if (percentageText) percentageText.textContent = '100';
          
          setTimeout(function() {
            var preloader = document.getElementById('preloader');
            if (preloader) {
              preloader.classList.add('fade-out');
              document.body.classList.add('preloader-done');
              window.dispatchEvent(new CustomEvent('preloader-complete'));
              setTimeout(function() {
                if (preloader.parentNode) {
                  preloader.parentNode.removeChild(preloader);
                }
              }, 600);
            }
          }, 200);
        }

        // Complete immediately on window load
        window.addEventListener('load', completePreloader);

        // Safety fallback: force fade out after 2.0 seconds if load event hangs
        setTimeout(completePreloader, 2000);
      })();
    </script>
